<IfModule mod_rewrite.c>
    RewriteEngine On

    Options -Indexes
    ServerSignature Off

    # Authorization-Header durchreichen
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # CORS-Preflight (OPTIONS) direkt an PHP
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ public/index.php [L]

    # Verzeichnisse blockieren
    RewriteRule ^bin/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^events/ - [F,L]
    RewriteRule ^src/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^templates/ - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.env - [F,L]

    # Alles an public/index.php weiterleiten (ausser existierende Dateien)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

# Sensitive Dateien blockieren
<FilesMatch "\.(env|log|sql|json|yaml|yml|md|lock|dist)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(composer\.json|composer\.lock|\.gitignore|\.gitmodules|AGENTS\.md|update\.sh)$">
    Require all denied
</FilesMatch>
