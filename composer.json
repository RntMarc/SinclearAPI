{
    "name": "sinclear/beyond-api",
    "description": "Sinclear Beyond REST API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "web-auth/webauthn-lib": "^5.0",
        "guzzlehttp/guzzle": "^7.9",
        "respect/validation": "^2.3",
        "ramsey/uuid": "^4.7",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.8",
        "symfony/mailer": "^7.2",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Sinclear\\Api\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse -c phpstan.neon",
        "phpcs": "phpcs --standard=PSR12 src",
        "phpcbf": "phpcbf --standard=PSR12 src"
    }
}
