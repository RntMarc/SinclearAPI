<IfModule mod_rewrite.c>
    RewriteEngine On

    Options -Indexes
    ServerSignature Off

    # Authorization-Header durchreichen
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # CORS-Preflight (OPTIONS) direkt an PHP
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ public/index.php [L]

    # Verzeichnisse blockieren
    RewriteRule ^bin/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^events/ - [F,L]
    RewriteRule ^src/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^templates/ - [F,L]
    RewriteRule ^SinclearApp/ - [F,L]
    RewriteRule ^var/ - [F,L]
    RewriteRule ^docs/ - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.env - [F,L]

    # Sensible Dateien blockieren
    RewriteRule ^generate_keys\.sh$ - [F,L]
    RewriteRule ^update\.sh$ - [F,L]

    # Alles an public/index.php weiterleiten (ausser existierende Dateien)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

# Sensitive Dateien blockieren
<FilesMatch "\.(env|log|sql|yaml|yml|md|lock|dist|sh)$">
    Require all denied
</FilesMatch>

# JSON-Dateien blockieren, ausser app_version.json
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>
<Files "app_version.json">
    Require all granted
</Files>

<FilesMatch "^(composer\.json|composer\.lock|\.gitignore|\.gitmodules|AGENTS\.md|update\.sh|generate_keys\.sh)$">
    Require all denied
</FilesMatch>
